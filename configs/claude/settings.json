{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "language": "japanese",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(cargo *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(mkdir *)"
    ],
    "deny": ["Bash(rm -rf *)", "Bash(git push *)", "Bash(curl *)"]
  },
  "plansDirectory": "./plans",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
